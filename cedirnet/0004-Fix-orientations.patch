Date: Wed, 13 May 2026 09:59:02 +0200
Subject: [PATCH 4/4] Fix orientations

---
 src/datasets/GenericDataset.py                  | 4 ++--
 src/models/center_estimator_with_orientation.py | 2 +-
 2 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/src/datasets/GenericDataset.py b/src/datasets/GenericDataset.py
index fe62c53..9827c82 100644
--- a/src/datasets/GenericDataset.py
+++ b/src/datasets/GenericDataset.py
@@ -125,8 +125,8 @@ class GenericDataset(Dataset):
 					pt1 = pt1 * self.resize_factor
 					pt2 = pt2 * self.resize_factor
 
-				direction = pt1 - pt2
-				direction = np.arctan2(direction[0], direction[1])
+				direction = pt2 - pt1
+				direction = np.arctan2(direction[1], direction[0])
 
 				orientation[:, int(pt1[1] - M):int(pt1[1] + M), int(pt1[0] - M):int(pt1[0] + M)] = direction
 				label[int(pt1[1] - M):int(pt1[1] + M), int(pt1[0] - M):int(pt1[0] + M)] = 1
diff --git a/src/models/center_estimator_with_orientation.py b/src/models/center_estimator_with_orientation.py
index 52fb2a4..dbd3684 100644
--- a/src/models/center_estimator_with_orientation.py
+++ b/src/models/center_estimator_with_orientation.py
@@ -54,7 +54,7 @@ class CenterOrientationEstimator(CenterEstimator):
                     x,y = pred[1:3]
                     s = sin_orientation[b,:,int(y), int(x)]
                     c = cos_orientation[b,:, int(y), int(x)]
-                    pred_angle = torch.atan2(c, s)
+                    pred_angle = torch.atan2(s, c)
 
                     pred_angle = torch.rad2deg(pred_angle)
                     pred_angle += 360 * (pred_angle < 0).int()
