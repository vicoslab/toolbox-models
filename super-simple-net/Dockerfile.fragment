ADD https://github.com/blaz-r/SuperSimpleNet.git .

COPY ${src}/*.patch .
RUN git apply *.patch && rm *.patch

RUN uv venv --python 3.12
RUN uv pip install -r requirements.txt
RUN uv pip install pytorch_lightning lightning opencv-python kornia tifffile psutil mlflow /opt/apps/modelargs flask gunicorn

COPY ${src}/train.py ${src}/infer.py ${src}/model.json .
